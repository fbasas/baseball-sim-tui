/* Baseball Simulation TUI - Game Dashboard Layout */

/* Main screen uses 3-column grid */
Screen {
    layout: grid;
    grid-size: 3;
    grid-columns: 1fr 2fr 1fr;
    grid-rows: auto 1fr;
}

/* Boxscore spans full width at top */
#boxscore {
    column-span: 3;
    height: 3;
    dock: top;
    border: solid $primary;
    padding: 0 1;
}

/* Score change highlight */
#boxscore.score-changed {
    background: $warning;
}

/* Left column: Away lineup */
#away-lineup {
    row-span: 1;
    border: solid $secondary;
    padding: 1;
}

/* Center column: Situation + Play log */
#center-panel {
    row-span: 1;
    layout: vertical;
}

#situation {
    height: 5;
    border: solid $secondary;
    padding: 1;
}

#play-log {
    border: solid $secondary;
    padding: 0 1;
    background: $surface;
    overflow-x: hidden;
}

/* Right column: Home lineup */
#home-lineup {
    row-span: 1;
    border: solid $secondary;
    padding: 1;
}

/* Current batter highlight */
.current-batter {
    background: $accent;
    text-style: bold;
}

/* End game menu modal */
EndGameMenu {
    align: center middle;
}

#menu {
    width: 40;
    height: auto;
    border: thick $primary;
    background: $surface;
    padding: 1 2;
}

#menu Button {
    width: 100%;
    margin: 1 0;
}

/* Substitution Menu Styles */
SubstitutionMenu {
    align: center middle;
}

#sub-menu-container {
    width: 100;
    height: 20;
    background: $surface;
    border: solid $primary;
    padding: 1 2;
}

#sub-title {
    text-align: center;
    margin-bottom: 1;
}

#pitcher-list, #batter-list {
    height: auto;
    max-height: 12;
    overflow-y: auto;
    padding: 1;
}

PlayerListItem {
    padding: 0 1;
}

PlayerListItem:hover {
    background: $primary-darken-2;
}

PlayerListItem:focus {
    background: $accent;
}

#sub-buttons {
    margin-top: 1;
    align: center middle;
}

#sub-buttons Button {
    margin: 0 1;
}

/* Fatigue Widget Styles */
#fatigue {
    height: 4;
    width: 100%;
    padding: 0 1;
    border: solid $primary-lighten-2;
}
